{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/KyoYagamiori/stock-report-data/schemas/snapshot.schema.json",
  "title": "Stock report snapshot v1.6.1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "snapshot_id",
    "workflow_run_id",
    "workflow_attempt",
    "snapshot_type",
    "snapshot_mode",
    "quality_profile",
    "quality_grade",
    "quality_reasons",
    "report_date",
    "report_cycle",
    "market_date",
    "market_session",
    "planned_at",
    "started_at",
    "published_at",
    "quote_time_min",
    "quote_time_max",
    "realtime_expected",
    "realtime_available",
    "suitable_reports",
    "coverage",
    "missing_core_fields",
    "missing_optional_fields",
    "warnings",
    "validation",
    "source_status",
    "market",
    "stocks"
  ],
  "properties": {
    "schema_version": {"const": "1.6.1"},
    "snapshot_id": {"type": "string", "minLength": 12},
    "workflow_run_id": {"type": "string", "minLength": 1},
    "workflow_attempt": {"type": "integer", "minimum": 1},
    "snapshot_type": {
      "enum": ["early", "noon", "close", "evening", "intraday"]
    },
    "snapshot_mode": {"enum": ["light", "full"]},
    "quality_profile": {
      "enum": [
        "trading_preopen",
        "trading_intraday",
        "trading_noon",
        "trading_close",
        "trading_evening",
        "non_trading"
      ]
    },
    "quality_grade": {"enum": ["A", "B", "F"]},
    "quality_reasons": {"type": "array", "items": {"type": "string"}},
    "blocking_reasons": {"type": "array", "items": {"type": "string"}},
    "degradation_actions": {"type": "array", "items": {"type": "string"}},
    "report_date": {"type": "string", "format": "date"},
    "report_cycle": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}-(early|noon|close|evening|intraday)$"
    },
    "market_date": {"type": "string", "format": "date"},
    "market_session": {
      "enum": ["preopen", "morning", "noon_close", "afternoon", "market_close", "evening_verified", "non_trading"]
    },
    "planned_at": {"type": "string", "format": "date-time"},
    "started_at": {"type": "string", "format": "date-time"},
    "published_at": {"type": "string", "format": "date-time"},
    "quote_time_min": {"type": ["string", "null"], "format": "date-time"},
    "quote_time_max": {"type": ["string", "null"], "format": "date-time"},
    "realtime_expected": {"type": "boolean"},
    "realtime_available": {"type": "boolean"},
    "based_on_snapshot_id": {"type": ["string", "null"]},
    "suitable_reports": {
      "type": "array",
      "items": {"enum": ["early", "noon", "evening"]},
      "uniqueItems": true
    },
    "coverage": {
      "type": "object",
      "required": ["indices", "core", "watch", "market_breadth", "sectors_top", "sectors_bottom"],
      "properties": {
        "indices": {"$ref": "#/$defs/coverageItem"},
        "core": {"$ref": "#/$defs/coverageItem"},
        "watch": {"$ref": "#/$defs/coverageItem"},
        "market_breadth": {"$ref": "#/$defs/coverageItem"},
        "sectors_top": {"$ref": "#/$defs/coverageItem"},
        "sectors_bottom": {"$ref": "#/$defs/coverageItem"}
      },
      "additionalProperties": {"$ref": "#/$defs/coverageItem"}
    },
    "missing_core_fields": {"type": "array", "items": {"type": "string"}},
    "missing_optional_fields": {"type": "array", "items": {"type": "string"}},
    "warnings": {"type": "array", "items": {"type": "string"}},
    "validation": {
      "type": "object",
      "required": ["schema_valid", "time_valid", "calendar_valid", "cross_field_valid"],
      "properties": {
        "schema_valid": {"type": "boolean"},
        "time_valid": {"type": "boolean"},
        "calendar_valid": {"type": "boolean"},
        "cross_field_valid": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "source_status": {"type": "object"},
    "market": {"type": "object"},
    "stocks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "name", "pool", "valid_quote"],
        "properties": {
          "code": {"type": "string", "pattern": "^[0-9]{6}$"},
          "name": {"type": "string", "minLength": 1},
          "pool": {"enum": ["core", "watch", "supplemental"]},
          "valid_quote": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    }
  },
  "$defs": {
    "coverageItem": {
      "type": "object",
      "required": ["valid", "expected", "ratio"],
      "properties": {
        "valid": {"type": "integer", "minimum": 0},
        "expected": {"type": "integer", "minimum": 0},
        "ratio": {"type": "number", "minimum": 0, "maximum": 1}
      },
      "additionalProperties": false
    }
  }
}
